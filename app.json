{
  "expo": {
    "name": "RistoAI",
    "slug": "Aldo",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/app-icon.png",
    "scheme": "aldo",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSMicrophoneUsageDescription": "RistoAI uses the microphone to convert your voice into chat messages."
      }
    },
    "android": {
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/android-adaptive-icon.png",
        "backgroundColor": "#FFFFFF"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.ristoai.app"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/app-icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-av",
        {
          "microphonePermission": "RistoAI uses the microphone to convert your voice into chat messages."
        }
      ],
      "expo-notifications",
      [
        "expo-localization",
        {
          "supportedLocales": {
            "ios": [
              "en",
              "it"
            ],
            "android": [
              "en",
              "it"
            ]
          }
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/image.png",
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#ffffff"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "apiUrl": "https://ristoai.onrender.com",
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "2ed6d18e-3954-4428-a5cc-afbbe2d094e1"
      }
    }
  }
}